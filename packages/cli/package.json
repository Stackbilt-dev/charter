{
  "name": "@stackbilt/cli",
  "sideEffects": false,
  "version": "0.13.0",
  "description": "Charter CLI — repo-level governance checks + architecture scaffolding",
  "bin": {
    "charter": "./dist/bin.js",
    "stackbilt": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Stackbilt-dev/charter.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/Stackbilt-dev/charter/issues"
  },
  "homepage": "https://github.com/Stackbilt-dev/charter#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "node ../../scripts/ensure-pnpm-publish.mjs",
    "build": "pnpm exec tsc -p tsconfig.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@stackbilt/adf": "^0.12.1",
    "@stackbilt/blast": "^0.12.1",
    "@stackbilt/classify": "^0.12.1",
    "@stackbilt/core": "^0.12.1",
    "@stackbilt/drift": "^0.12.1",
    "@stackbilt/git": "^0.12.1",
    "@stackbilt/surface": "^0.12.1",
    "@stackbilt/types": "^0.12.1",
    "@stackbilt/validate": "^0.12.1"
  },
  "license": "Apache-2.0",
  "author": "Stackbilt LLC"
}
