{
  "name": "@stackbilt/cli",
  "sideEffects": false,
  "version": "0.9.3",
  "description": "Charter CLI — repo-level governance checks + architecture scaffolding",
  "bin": {
    "charter": "./dist/bin.js",
    "stackbilt": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Stackbilt-dev/charter.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/Stackbilt-dev/charter/issues"
  },
  "homepage": "https://github.com/Stackbilt-dev/charter#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@stackbilt/adf": "workspace:^",
    "@stackbilt/classify": "workspace:^",
    "@stackbilt/contracts": "file:../../../contracts",
    "@stackbilt/core": "workspace:^",
    "@stackbilt/drift": "workspace:^",
    "@stackbilt/git": "workspace:^",
    "@stackbilt/types": "workspace:^",
    "@stackbilt/validate": "workspace:^"
  },
  "license": "Apache-2.0",
  "author": "Stackbilt LLC"
}
